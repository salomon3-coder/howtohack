---
import Layout from "../layouts/Layout.astro";

const pageTitle = "Editorial Policy | HowToHack";
const pageDescription = "How HowToHack creates, reviews, and updates practical how-to content.";
---

<Layout title={pageTitle} description={pageDescription}>
	<main>
		<article class="post">
			<p class="eyebrow">Standards</p>
			<h1>Editorial Policy</h1>
			<p class="muted">Last updated: 2026-03-23</p>

			<h2>Mission</h2>
			<p>
				Publish useful, ethical, reader-first how-to content that helps people solve everyday problems.
			</p>

			<h2>Content quality standards</h2>
			<ul>
				<li>English-first, clear writing aimed at non-experts.</li>
				<li>Actionable steps, realistic outcomes, and practical safety notes.</li>
				<li>No illegal hacking, abuse, or harmful guidance.</li>
				<li>No fabricated statistics or misleading claims.</li>
			</ul>

			<h2>Originality and updates</h2>
			<p>
				We avoid duplicate topics, publish fresh angles, and update or remove low-value/overlapping content.
			</p>

			<h2>Image standards</h2>
			<p>
				We use real, non-AI images from free stock sources with attribution metadata when available.
			</p>

			<h2>Corrections policy</h2>
			<p>
				When errors are reported and verified, we update the content promptly. Send correction requests to
				<a href="mailto:contact@howtohack.net">contact@howtohack.net</a>.
			</p>
		</article>
	</main>
</Layout>
