---
import { getCollection } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import PostCard from "../../../components/PostCard.astro";

const PAGE_SIZE = 6;

const allPosts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));

export async function getStaticPaths() {
	const pageSize = 6;
	const posts = await getCollection("blog", ({ data }) => !data.draft);
	const total = Math.max(1, Math.ceil(posts.length / pageSize));
	return Array.from({ length: Math.max(0, total - 1) }, (_, idx) => ({
		params: { page: String(idx + 2) },
	}));
}

const currentPage = Number.parseInt(Astro.params.page ?? "1", 10);
const safePage = Number.isFinite(currentPage) && currentPage >= 1 ? currentPage : 1;
const offset = (safePage - 1) * PAGE_SIZE;
const posts = allPosts.slice(offset, offset + PAGE_SIZE);

const formatDate = (date) =>
	new Intl.DateTimeFormat("en-US", { day: "2-digit", month: "short", year: "numeric" }).format(date);
const getReadingMinutes = (post) => {
	const words = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
	return Math.max(1, Math.ceil(words / 220));
};
---

<Layout title={`Blog page ${safePage} | HowToHack`} description="Paginated archive of HowToHack articles.">
	<main>
		<section class="hero hero-blog">
			<p class="eyebrow">HowToHack Magazine</p>
			<h1>Latest articles — page {safePage}</h1>
			<p class="muted hero-blog__lead">Browse the full archive of published guides.</p>
		</section>
		<div class="blog-grid">
			{
				posts.map((post) => {
					const slug = (post.slug ?? post.id).replace(/\.md$/, "");
					return (
						<PostCard
							href={`/blog/${slug}/`}
							title={post.data.title}
							description={post.data.description}
							category={post.data.category}
							dateLabel={formatDate(post.data.pubDate)}
							readMinutes={getReadingMinutes(post)}
							imageUrl={post.data.image?.url}
							imageAlt={post.data.image?.alt}
						/>
					);
				})
			}
		</div>
		<nav class="pagination" aria-label="Article pagination">
			<a class={`page-pill ${safePage === 1 ? "active" : ""}`} href="/blog/">
				1
			</a>
			{
				Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => i + 2).map((page) => (
					<a class={`page-pill ${safePage === page ? "active" : ""}`} href={`/blog/page/${page}/`}>
						{page}
					</a>
				))
			}
		</nav>
	</main>
</Layout>
