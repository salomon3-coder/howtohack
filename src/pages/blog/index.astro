---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Layout
	title="Blog | HowToHack"
	description="Hacks eticos diarios para resolver problemas comunes paso a paso."
>
	<main>
		<h1>Articulos recientes</h1>
		<p class="muted">Selecciona una guia y sigue los pasos. Todo orientado a resultados practicos.</p>
		<div class="grid">
			{
				posts.map((post) => (
					<article class="card">
						<h3>
						<a href={`/blog/${(post.slug ?? post.id).replace(/\.md$/, "")}/`}>{post.data.title}</a>
						</h3>
						<p>{post.data.description}</p>
					</article>
				))
			}
		</div>
	</main>
</Layout>
