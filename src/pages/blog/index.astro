---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const PAGE_SIZE = 6;
const currentPage = 1;
const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
const pagedPosts = posts.slice(0, PAGE_SIZE);

const formatDate = (date) =>
	new Intl.DateTimeFormat("es-CL", { day: "2-digit", month: "short", year: "numeric" }).format(date);

const getReadingMinutes = (post) => {
	const words = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
	return Math.max(1, Math.ceil(words / 220));
};
---

<Layout
	title="Blog | HowToHack"
	description="Hacks eticos diarios para resolver problemas comunes paso a paso."
>
	<main>
		<section class="hero hero-blog">
			<p class="eyebrow">HowToHack Magazine</p>
			<h1>Articulos recientes</h1>
			<p class="muted">
				Selecciona una guia y sigue los pasos. Todo orientado a resultados practicos y lectura
				agradable desde movil o escritorio.
			</p>
		</section>
		<input
			class="search-bar"
			id="blog-search"
			type="search"
			placeholder="Buscar por titulo, descripcion o categoria..."
		/>
		<div class="grid">
			{
				pagedPosts.map((post) => (
					<article
						class="card"
						data-search={`${post.data.title} ${post.data.description} ${post.data.category}`.toLowerCase()}
					>
						<p class="meta-line">
							<span class="badge">{post.data.category}</span>
							<span>{formatDate(post.data.pubDate)}</span>
							<span>{getReadingMinutes(post)} min lectura</span>
						</p>
						<h3>
							<a href={`/blog/${(post.slug ?? post.id).replace(/\.md$/, "")}/`}>{post.data.title}</a>
						</h3>
						<p class="muted">{post.data.description}</p>
						<p><a href={`/blog/${(post.slug ?? post.id).replace(/\.md$/, "")}/`}>Leer articulo</a></p>
					</article>
				))
			}
		</div>
		<nav class="pagination" aria-label="Paginacion de articulos">
			<a class={`page-pill ${currentPage === 1 ? "active" : ""}`} href="/blog/">
				1
			</a>
			{
				Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => i + 2).map((page) => (
					<a class="page-pill" href={`/blog/page/${page}/`}>
						{page}
					</a>
				))
			}
		</nav>
	</main>
</Layout>

<script>
	const searchInput = document.getElementById("blog-search");
	const cards = Array.from(document.querySelectorAll(".card[data-search]"));
	searchInput?.addEventListener("input", (event) => {
		const value = (event.target.value || "").toLowerCase().trim();
		cards.forEach((card) => {
			const match = card.dataset.search?.includes(value);
			card.style.display = match ? "" : "none";
		});
	});
</script>
