---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/PostCard.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const PAGE_SIZE = 6;
const currentPage = 1;
const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
const pagedPosts = posts.slice(0, PAGE_SIZE);

const formatDate = (date) =>
	new Intl.DateTimeFormat("en-US", { day: "2-digit", month: "short", year: "numeric" }).format(date);

const getReadingMinutes = (post) => {
	const words = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
	return Math.max(1, Math.ceil(words / 220));
};
---

<Layout
	title="Blog | HowToHack"
	description="Daily ethical hacks to solve common problems step by step."
>
	<main>
		<section class="hero hero-blog">
			<p class="eyebrow">HowToHack Magazine</p>
			<h1>Latest articles</h1>
			<p class="muted hero-blog__lead">
				Pick a guide and follow each step. Everything is built for practical results and smooth
				reading on mobile and desktop.
			</p>
		</section>
		<input
			class="search-bar"
			id="blog-search"
			type="search"
			placeholder="Search by title, description, or category..."
			autocomplete="off"
		/>
		<div class="blog-grid">
			{
				pagedPosts.map((post) => {
					const slug = (post.slug ?? post.id).replace(/\.md$/, "");
					return (
						<PostCard
							href={`/blog/${slug}/`}
							title={post.data.title}
							description={post.data.description}
							category={post.data.category}
							dateLabel={formatDate(post.data.pubDate)}
							readMinutes={getReadingMinutes(post)}
							imageUrl={post.data.image?.url}
							imageAlt={post.data.image?.alt}
							searchBlob={`${post.data.title} ${post.data.description} ${post.data.category}`.toLowerCase()}
						/>
					);
				})
			}
		</div>
		<nav class="pagination" aria-label="Article pagination">
			<a class={`page-pill ${currentPage === 1 ? "active" : ""}`} href="/blog/">
				1
			</a>
			{
				Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => i + 2).map((page) => (
					<a class="page-pill" href={`/blog/page/${page}/`}>
						{page}
					</a>
				))
			}
		</nav>
	</main>
</Layout>

<script>
	const searchInput = document.getElementById("blog-search");
	const cards = Array.from(document.querySelectorAll(".card-post[data-search]"));
	searchInput?.addEventListener("input", (event) => {
		const value = (event.target.value || "").toLowerCase().trim();
		cards.forEach((card) => {
			const match = card.dataset.search?.includes(value);
			card.style.display = match ? "" : "none";
		});
	});
</script>
