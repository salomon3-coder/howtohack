---
import Layout from "../layouts/Layout.astro";

const pageTitle = "Privacy Policy | HowToHack";
const pageDescription = "How HowToHack handles analytics, advertising, and basic visitor data.";
---

<Layout title={pageTitle} description={pageDescription}>
	<main>
		<article class="post">
			<p class="eyebrow">Legal</p>
			<h1>Privacy Policy</h1>
			<p class="muted">Last updated: 2026-03-23</p>

			<p>
				HowToHack respects user privacy. This policy explains what data may be collected and how it is
				used.
			</p>

			<h2>Information we collect</h2>
			<ul>
				<li>Basic usage analytics (pageviews, device/browser, referral source).</li>
				<li>Technical logs needed for security and website reliability.</li>
			</ul>

			<h2>Analytics</h2>
			<p>
				We may use Google Analytics to understand website performance and improve content quality.
			</p>

			<h2>Advertising</h2>
			<p>
				We may display Google AdSense ads. Ad providers may use cookies or similar technologies according
				to their policies.
			</p>

			<h2>Third-party services</h2>
			<p>
				External services (e.g., analytics/ads) operate under their own terms and privacy policies.
			</p>

			<h2>Your choices</h2>
			<p>
				You can control cookies from your browser settings and use ad personalization controls offered by
				Google.
			</p>

			<h2>Contact</h2>
			<p>
				For privacy questions, email <a href="mailto:contact@howtohack.net">contact@howtohack.net</a>.
			</p>
		</article>
	</main>
</Layout>
