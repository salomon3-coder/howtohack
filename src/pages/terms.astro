---
import Layout from "../layouts/Layout.astro";

const pageTitle = "Terms of Use | HowToHack";
const pageDescription = "Terms and conditions for using howtohack.net content.";
---

<Layout title={pageTitle} description={pageDescription}>
	<main>
		<article class="post">
			<p class="eyebrow">Legal</p>
			<h1>Terms of Use</h1>
			<p class="muted">Last updated: 2026-03-23</p>

			<h2>Use of content</h2>
			<p>
				Content on HowToHack is for informational and educational purposes. You are responsible for how you
				apply any tutorial or recommendation.
			</p>

			<h2>No professional advice</h2>
			<p>
				Our guides do not replace professional legal, financial, medical, or technical advice.
			</p>

			<h2>Acceptable use</h2>
			<p>
				You may not use this site to support illegal, harmful, abusive, or unauthorized activities.
			</p>

			<h2>External links</h2>
			<p>
				We may link to external websites. We are not responsible for their content or privacy practices.
			</p>

			<h2>Changes</h2>
			<p>
				We may update these terms as the site evolves. Continued use means you accept the latest version.
			</p>

			<h2>Contact</h2>
			<p>
				Questions about these terms: <a href="mailto:contact@howtohack.net">contact@howtohack.net</a>
			</p>
		</article>
	</main>
</Layout>
