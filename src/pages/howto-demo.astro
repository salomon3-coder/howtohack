---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'How to restart a router in 5 steps';
const pageDescription = 'Quick tutorial to restart a router without losing configuration.';

const howToSchema = {
	'@context': 'https://schema.org',
	'@type': 'HowTo',
	name: pageTitle,
	description: pageDescription,
	totalTime: 'PT10M',
	supply: [
		{
			'@type': 'HowToSupply',
			name: 'Router and power cable',
		},
	],
	tool: [
		{
			'@type': 'HowToTool',
			name: 'Phone or laptop to test connection',
		},
	],
	step: [
		{
			'@type': 'HowToStep',
			name: 'Turn off the router',
			text: 'Unplug the router from power.',
		},
		{
			'@type': 'HowToStep',
			name: 'Wait 30 seconds',
			text: 'Allow temporary memory to clear.',
		},
		{
			'@type': 'HowToStep',
			name: 'Turn it back on',
			text: 'Plug it back in and wait until it fully boots.',
		},
	],
};
---

<Layout title={pageTitle} description={pageDescription} schema={howToSchema}>
	<main>
		<h1>{pageTitle}</h1>
		<p>This page is a reference template for HowTo schema content.</p>
	</main>
</Layout>
