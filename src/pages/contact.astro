---
import Layout from "../layouts/Layout.astro";

const pageTitle = "Contact HowToHack";
const pageDescription =
	"Get in touch with HowToHack for corrections, editorial feedback, and business inquiries.";

const schema = {
	"@context": "https://schema.org",
	"@type": "ContactPage",
	name: pageTitle,
	description: pageDescription,
	url: "https://howtohack.net/contact/",
};
---

<Layout title={pageTitle} description={pageDescription} schema={schema}>
	<main>
		<article class="post">
			<p class="eyebrow">Contact</p>
			<h1>Contact HowToHack</h1>
			<p class="muted">
				Need to report an issue, request a correction, or discuss partnerships? We read every message.
			</p>

			<h2>Email</h2>
			<p>
				Primary contact: <a href="mailto:contact@howtohack.net">contact@howtohack.net</a>
			</p>

			<h2>What to include for corrections</h2>
			<ul>
				<li>Article URL</li>
				<li>The line or section to review</li>
				<li>Suggested correction and, if possible, source reference</li>
			</ul>

			<h2>Response window</h2>
			<p>
				We typically respond within 2-5 business days. Critical safety issues are prioritized.
			</p>
		</article>
	</main>
</Layout>
