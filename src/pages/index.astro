---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const latestPosts = (await getCollection("blog", ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 10);

const featuredPost = latestPosts[0];
const otherPosts = latestPosts.slice(1, 7);

const formatDate = (date) =>
	new Intl.DateTimeFormat("es-CL", { day: "2-digit", month: "short", year: "numeric" }).format(date);

const getReadingMinutes = (post) => {
	const words = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
	return Math.max(1, Math.ceil(words / 220));
};
---

<Layout
	title="HowToHack | Soluciones practicas paso a paso"
	description="Hacks eticos y guias claras para resolver problemas de hogar, trabajo y software."
>
	<main>
		<section class="hero">
			<p class="eyebrow">HowToHack Magazine</p>
			<h1>Un sitio que te explica todo facil, practico y sin humo</h1>
			<p class="muted">
				Guias claras y eticas para hogar, trabajo y software. Publicamos soluciones accionables
				pensadas para personas reales, no para expertos.
			</p>
			<div class="hero-actions">
				<a class="btn" href="/blog/">Explorar articulos</a>
				<a class="btn secondary" href="/blog/">Ver lo mas nuevo</a>
			</div>
		</section>

		<section class="split">
			<article class="panel">
				<h3>Por que HowToHack funciona</h3>
				<p class="muted">
					Explicamos paso a paso, evitamos tecnicismos innecesarios y priorizamos acciones seguras
					que puedas aplicar hoy.
				</p>
				<ul class="mini-list">
					<li>Guias cortas, utiles y orientadas a resultados</li>
					<li>Enfoque etico: resolver, optimizar, mejorar</li>
					<li>Contenido actualizado y pensado para SEO real</li>
				</ul>
			</article>
			<article class="panel">
				<h3>Categorias principales</h3>
				<ul class="mini-list">
					<li><strong>Hogar:</strong> ahorro, mantenimiento y soluciones cotidianas</li>
					<li><strong>Software:</strong> errores comunes, rendimiento y productividad</li>
					<li><strong>Empresa:</strong> procesos, equipos y trabajo digital</li>
					<li><strong>Online:</strong> seguridad, cuentas y herramientas web</li>
				</ul>
			</article>
		</section>

		{
			featuredPost && (
				<section class="featured">
					<p class="meta-line">
						<span class="badge">{featuredPost.data.category}</span>
						<span>{formatDate(featuredPost.data.pubDate)}</span>
						<span>{getReadingMinutes(featuredPost)} min lectura</span>
					</p>
					<h2>
						<a href={`/blog/${(featuredPost.slug ?? featuredPost.id).replace(/\.md$/, "")}/`}>
							{featuredPost.data.title}
						</a>
					</h2>
					<p class="muted">{featuredPost.data.description}</p>
				</section>
			)
		}

		<h2>Ultimos publicados</h2>
		<div class="grid">
			{
				otherPosts.map((post) => (
					<article class="card">
						<p class="meta-line">
							<span class="badge">{post.data.category}</span>
							<span>{formatDate(post.data.pubDate)}</span>
							<span>{getReadingMinutes(post)} min lectura</span>
						</p>
						<h3>
							<a href={`/blog/${(post.slug ?? post.id).replace(/\.md$/, "")}/`}>{post.data.title}</a>
						</h3>
						<p class="muted">{post.data.description}</p>
						<p><a href={`/blog/${(post.slug ?? post.id).replace(/\.md$/, "")}/`}>Seguir leyendo</a></p>
					</article>
				))
			}
		</div>
	</main>
</Layout>
