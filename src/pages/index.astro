---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const latestPosts = (await getCollection("blog", ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 10);

const featuredPost = latestPosts[0];
const otherPosts = latestPosts.slice(1, 7);

const formatDate = (date) =>
	new Intl.DateTimeFormat("en-US", { day: "2-digit", month: "short", year: "numeric" }).format(date);

const getReadingMinutes = (post) => {
	const words = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
	return Math.max(1, Math.ceil(words / 220));
};
---

<Layout
	title="HowToHack | Practical step-by-step solutions"
	description="Ethical hacks and easy guides for home, work, and software problems."
>
	<main>
		<section class="hero">
			<p class="eyebrow">HowToHack Magazine</p>
			<h1>A no-fluff website that helps you fix things fast</h1>
			<p class="muted">
				Clear and ethical guides for home, work, and software. We publish actionable solutions
				built for real people, not just experts.
			</p>
			<div class="hero-actions">
				<a class="btn" href="/blog/">Explore articles</a>
				<a class="btn secondary" href="/blog/">See latest posts</a>
			</div>
		</section>

		<section class="split">
			<article class="panel">
				<h3>Why HowToHack works</h3>
				<p class="muted">
					We explain things step by step, avoid unnecessary jargon, and prioritize safe actions
					you can apply today.
				</p>
				<ul class="mini-list">
					<li>Short, practical, results-focused guides</li>
					<li>Ethical approach: solve, optimize, improve</li>
					<li>Fresh content designed for real SEO outcomes</li>
				</ul>
			</article>
			<article class="panel">
				<h3>Main categories</h3>
				<ul class="mini-list">
					<li><strong>Home:</strong> savings, maintenance, daily fixes</li>
					<li><strong>Software:</strong> common errors, speed, productivity</li>
					<li><strong>Business:</strong> processes, teamwork, digital workflows</li>
					<li><strong>Online:</strong> security, accounts, web tools</li>
				</ul>
			</article>
		</section>

		{
			featuredPost && (
				<section class="featured">
					<p class="meta-line">
						<span class="badge">{featuredPost.data.category}</span>
						<span>{formatDate(featuredPost.data.pubDate)}</span>
						<span>{getReadingMinutes(featuredPost)} min read</span>
					</p>
					<h2>
						<a href={`/blog/${(featuredPost.slug ?? featuredPost.id).replace(/\.md$/, "")}/`}>
							{featuredPost.data.title}
						</a>
					</h2>
					<p class="muted">{featuredPost.data.description}</p>
				</section>
			)
		}

		<h2>Latest published</h2>
		<div class="grid">
			{
				otherPosts.map((post) => (
					<article class="card">
						<p class="meta-line">
							<span class="badge">{post.data.category}</span>
							<span>{formatDate(post.data.pubDate)}</span>
							<span>{getReadingMinutes(post)} min read</span>
						</p>
						<h3>
							<a href={`/blog/${(post.slug ?? post.id).replace(/\.md$/, "")}/`}>{post.data.title}</a>
						</h3>
						<p class="muted">{post.data.description}</p>
						<p><a href={`/blog/${(post.slug ?? post.id).replace(/\.md$/, "")}/`}>Read article</a></p>
					</article>
				))
			}
		</div>
	</main>
</Layout>
