---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'FAQ: mejorar velocidad de internet en casa';
const pageDescription = 'Preguntas y respuestas clave para optimizar tu red WiFi.';

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'Donde ubicar el router para mejor senal?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Ubicalo en una zona centrada y elevada, lejos de paredes gruesas y microondas.',
			},
		},
		{
			'@type': 'Question',
			name: 'Conviene usar banda 5GHz o 2.4GHz?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: '5GHz es mas rapida a corta distancia; 2.4GHz cubre mas area con menos velocidad.',
			},
		},
	],
};
---

<Layout title={pageTitle} description={pageDescription} schema={faqSchema}>
	<main>
		<h1>{pageTitle}</h1>
		<p>Esta pagina es una plantilla de referencia para contenido con schema FAQPage.</p>
	</main>
</Layout>
