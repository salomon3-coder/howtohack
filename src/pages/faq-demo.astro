---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'FAQ: How to improve home internet speed';
const pageDescription = 'Key questions and answers to optimize your home Wi-Fi network.';

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'Where should I place my router for stronger signal?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Place it in a central, elevated location away from thick walls and microwaves.',
			},
		},
		{
			'@type': 'Question',
			name: 'Should I use 5GHz or 2.4GHz?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: '5GHz is faster at short range; 2.4GHz has better coverage but lower speed.',
			},
		},
	],
};
---

<Layout title={pageTitle} description={pageDescription} schema={faqSchema}>
	<main>
		<h1>{pageTitle}</h1>
		<p>This page is a reference template for FAQPage schema content.</p>
	</main>
</Layout>
