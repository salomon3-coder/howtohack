---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Como liberar espacio en Windows sin borrar archivos importantes';
const pageDescription =
	'Guia paso a paso para limpiar espacio en disco en Windows de forma segura.';
const pageUrl = 'https://howtohack.net/article-demo';
const imageUrl = 'https://howtohack.net/images/windows-cleanup.jpg';

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: pageTitle,
	description: pageDescription,
	author: {
		'@type': 'Organization',
		name: 'HowToHack',
	},
	publisher: {
		'@type': 'Organization',
		name: 'HowToHack',
	},
	datePublished: '2026-03-20',
	dateModified: '2026-03-20',
	mainEntityOfPage: pageUrl,
	image: [imageUrl],
};
---

<Layout title={pageTitle} description={pageDescription} schema={articleSchema}>
	<main>
		<h1>{pageTitle}</h1>
		<p>Esta pagina es una plantilla de referencia para articulos con schema Article.</p>
	</main>
</Layout>
