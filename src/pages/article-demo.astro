---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'How to free up Windows disk space safely';
const pageDescription =
	'Step-by-step guide to clean up disk space in Windows without deleting important files.';
const pageUrl = 'https://howtohack.net/article-demo';
const imageUrl = 'https://howtohack.net/images/windows-cleanup.jpg';

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: pageTitle,
	description: pageDescription,
	author: {
		'@type': 'Organization',
		name: 'HowToHack',
	},
	publisher: {
		'@type': 'Organization',
		name: 'HowToHack',
	},
	datePublished: '2026-03-20',
	dateModified: '2026-03-20',
	mainEntityOfPage: pageUrl,
	image: [imageUrl],
};
---

<Layout title={pageTitle} description={pageDescription} schema={articleSchema}>
	<main>
		<h1>{pageTitle}</h1>
		<p>This page is a reference template for Article schema content.</p>
	</main>
</Layout>
