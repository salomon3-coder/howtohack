---
import StructuredData from '../components/StructuredData.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import AdSenseLoader from '../components/AdSenseLoader.astro';
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
	title = 'HowToHack | Ethical practical guides',
	description = 'Practical guides to solve common home, business, and software problems the easy way.',
	schema,
} = Astro.props;
const canonicalHref = new URL(`${Astro.url.pathname}${Astro.url.search}`, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,600;0,9..144,700;1,9..144,600&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalHref} />
		<StructuredData data={schema} />
		<GoogleAnalytics />
		<AdSenseLoader />
	</head>
	<body>
		<header class="site-header">
			<div class="header-wrap">
				<a class="brand" href="/">
					<img
						class="brand__mark"
						src="/brand/logo-mark.svg"
						width="40"
						height="40"
						alt=""
						aria-hidden="true"
					/>
					<span class="brand__text">
						<span class="brand__name">HowToHack</span>
						<span class="brand__tag">Magazine</span>
					</span>
				</a>
				<nav class="nav" aria-label="Main">
					<a class="nav__link" href="/">Home</a>
					<a class="nav__link" href="/blog/">Blog</a>
					<a class="nav__link" href="/about/">About</a>
					<a class="nav__link" href="/contact/">Contact</a>
					<button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
						<span class="theme-icon" aria-hidden="true">◐</span>
						<span class="theme-label">Dark mode</span>
					</button>
				</nav>
			</div>
		</header>
		<div class="container">
			<slot />
		</div>
		<footer class="site-footer">
			<div class="footer-wrap">
				<div class="footer-brand">
					<img src="/brand/logo-mark.svg" width="36" height="36" alt="" aria-hidden="true" />
					<div>
						<strong class="footer-brand__name">HowToHack</strong>
						<p class="footer-brand__tag muted">Ethical how-tos for real life.</p>
					</div>
				</div>
				<nav class="footer-nav" aria-label="Footer">
					<a href="/">Home</a>
					<a href="/blog/">Blog</a>
					<a href="/about/">About</a>
					<a href="/contact/">Contact</a>
					<a href="/privacy/">Privacy</a>
					<a href="/terms/">Terms</a>
					<a href="/editorial-policy/">Editorial Policy</a>
				</nav>
				<p class="footer-copy muted">© {new Date().getFullYear()} HowToHack. Practical guides only.</p>
			</div>
		</footer>
		<script>
			const root = document.documentElement;
			const storageKey = "howtohack-theme";
			const btn = document.getElementById("theme-toggle");
			const label = btn?.querySelector(".theme-label");
			const apply = (theme) => {
				root.dataset.theme = theme;
				if (label) label.textContent = theme === "dark" ? "Light mode" : "Dark mode";
			};
			const saved = localStorage.getItem(storageKey);
			if (saved === "dark" || saved === "light") {
				apply(saved);
			} else {
				apply(window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
			}
			btn?.addEventListener("click", () => {
				const next = root.dataset.theme === "dark" ? "light" : "dark";
				apply(next);
				localStorage.setItem(storageKey, next);
			});
		</script>
	</body>
</html>
